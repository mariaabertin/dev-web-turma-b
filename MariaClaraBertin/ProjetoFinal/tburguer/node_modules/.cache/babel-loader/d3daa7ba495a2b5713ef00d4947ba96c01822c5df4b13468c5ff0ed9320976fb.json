{"ast":null,"code":"export default {\n  name: \"PedidoComponent\",\n  props: {\n    burguer: null\n  },\n  data() {\n    return {\n      listaPontosCarne: [],\n      listaComplementos: [],\n      listaBebidas: [],\n      nomeCliente: \"\",\n      pontoCarneSelecionado: \"\",\n      listaComplementosSelecionados: [],\n      listaBebidasSelecionadas: []\n    };\n  },\n  methods: {\n    async getTiposPontos() {\n      const response = await fetch(\"http://localhost:3000/tipos_pontos\");\n      const dados = await respose.json();\n      this.listaPontosCarne = dados;\n    },\n    async getOpcionais() {\n      const response = await fetch(\"http://localhost:3000/opcionais\");\n      const dados = await response.json();\n      this.listaComplementos = dados.complemento;\n      this.listaBebidas = dados.bebidas;\n    },\n    async getBebidas() {\n      const response = await fetch(\"http://localhost:3000/opcionais\");\n      const dados = await response.json();\n      this.listaBebidas = dados.bebidas;\n    },\n    async criarPedido(e) {\n      const dadosPedido = {\n        nome: this.nomeCliente,\n        ponto: this.pontoCarneSelecionado,\n        bebidas: Array.from(this.listaBebidasSelecionadas),\n        complemento: Array.from(this.listaComplementosSelecionados),\n        burguer: this.burguer,\n        statusId: 5\n      };\n      console.log(dadosPedido);\n      const dadosJson = JSON.stringify(dadosPedido);\n      const req = await fetch(\"http://localhost:3000/pedidos\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\"\n        },\n        body: dadosJson\n      });\n    }\n  },\n  mounted() {\n    this.getTiposPontos();\n    this.getOpcionais();\n  }\n};","map":{"version":3,"names":["name","props","burguer","data","listaPontosCarne","listaComplementos","listaBebidas","nomeCliente","pontoCarneSelecionado","listaComplementosSelecionados","listaBebidasSelecionadas","methods","getTiposPontos","response","fetch","dados","respose","json","getOpcionais","complemento","bebidas","getBebidas","criarPedido","e","dadosPedido","nome","ponto","Array","from","statusId","console","log","dadosJson","JSON","stringify","req","method","headers","body","mounted"],"sources":["C:\\Users\\bertinmaria\\Desktop\\githubMB\\dev-web-turma-b\\MariaClaraBertin\\ProjetoFinal\\tburguer\\src\\components\\PedidoComponent.vue"],"sourcesContent":["<template>\r\n    <div>\r\n        <form id=\"pedido-form\" @submit=\"criarPedido($event)\">\r\n        <div>\r\n            <p id=\"nome-hamburguer-content\">\r\n                {{ burguer && burguer.nome ? burguer.nome : \"--\"}}\r\n            </p>\r\n            <img id=\"foto-content\" :src=\"burguer && burguer.foto ? burguer.foto : ''\">\r\n        </div>\r\n\r\n        <div class=\"inputs\" id=\"form-pedido\">\r\n            <label>Nome</label>\r\n            <input v-model=\"nomeCliente\" type=\"text\" placeholder=\"Digite seu Nome\" id=\"nome-cliente\">\r\n        </div>\r\n\r\n        <div class=\"inputs\" id=\"form-pedido\">\r\n            <label>Ponto da Carne</label>\r\n            <select v-model=\"pontoCarneSelecionado\" name=\"ponto-carne\" id=\"ponto-carne\">\r\n                <option value=\"\" selected>Selecione Ponto</option>\r\n                <option v-for=\"pontoCarne in listaPontosCarne\" :key=\"pontoCarne.id\" value=\"pontoCarne\">{{pontoCarne.descricao}}</option>\r\n            </select>\r\n        </div>\r\n\r\n        <div class=\"inputs\" id=\"form-pedido\">\r\n            <label id=\"opcionais-titulo\">Selecione os opcionais</label>\r\n            \r\n            <label id=\"opcionais-subtitulo\">Selecione os complementos</label>\r\n            <div v-for=\"complemento in listaComplementos\" :key=\"complemento.id\" class=\"checkbox-container\">\r\n                <input type=\"checkbox\" \r\n                :name=\"complemento.nome\" \r\n                :value=\"complemento\" \r\n                v-model=\"listaComplementosSelecionados\">\r\n                <span>{{complemento.nome}}</span>\r\n            </div>\r\n\r\n            <label>Adicione uma bebida</label>\r\n            <div v-for=\"bebida in listaBebidas\" :key=\"bebida.id\" class=\"checkbox-container\">\r\n                <input type=\"checkbox\"\r\n                :name=\"bebida.nome\"\r\n                :value=\"bebida\"\r\n                v-model=\"listaBebidasSelecionadas\">\r\n                <span>{{bebida.nome}}</span>\r\n            </div>\r\n        </div>\r\n\r\n        <div class=\"inputs\">\r\n            <input type=\"submit\" class=\"submit-btn\" value=\"Confirmar Pedido\">\r\n        </div>\r\n        </form>\r\n    </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n    name: \"PedidoComponent\",\r\n    props: {\r\n        burguer: null,\r\n    },\r\n    data() {\r\n        return {\r\n            listaPontosCarne: [],\r\n            listaComplementos: [],\r\n            listaBebidas: [],\r\n            nomeCliente: \"\",\r\n            pontoCarneSelecionado: \"\",\r\n            listaComplementosSelecionados: [],\r\n            listaBebidasSelecionadas: [],\r\n        };\r\n    },\r\n    methods: {\r\n        async getTiposPontos() {\r\n            const response = await fetch(\"http://localhost:3000/tipos_pontos\");\r\n            const dados = await respose.json();\r\n            this.listaPontosCarne = dados;\r\n        },\r\n        async getOpcionais() {\r\n            const response = await fetch(\"http://localhost:3000/opcionais\");\r\n            const dados = await response.json();\r\n            this.listaComplementos = dados.complemento;\r\n            this.listaBebidas = dados.bebidas;\r\n        },\r\n        async getBebidas() {\r\n            const response = await fetch(\"http://localhost:3000/opcionais\");\r\n            const dados = await response.json();\r\n            this.listaBebidas = dados.bebidas;\r\n        },\r\n        async criarPedido(e) {\r\n            const dadosPedido = {\r\n                nome: this.nomeCliente,\r\n                ponto: this.pontoCarneSelecionado,\r\n                bebidas: Array.from(this.listaBebidasSelecionadas),\r\n                complemento: Array.from(this.listaComplementosSelecionados),\r\n                burguer: this.burguer,\r\n                statusId: 5,\r\n            };\r\n\r\n            console.log(dadosPedido);\r\n\r\n            const dadosJson = JSON.stringify(dadosPedido);\r\n\r\n            const req = await fetch(\"http://localhost:3000/pedidos\", {\r\n                method: \"POST\",\r\n                headers: { \"Content-Type\": \"application/json\" },\r\n                body: dadosJson,\r\n            });\r\n        },\r\n\r\n    },\r\n    mounted() {\r\n        this.getTiposPontos();\r\n        this.getOpcionais();\r\n    },\r\n};\r\n</script>\r\n\r\n<style></style>"],"mappings":"AAqDA,eAAe;EACXA,IAAI,EAAE,iBAAiB;EACvBC,KAAK,EAAE;IACHC,OAAO,EAAE;EACb,CAAC;EACDC,IAAIA,CAAA,EAAG;IACH,OAAO;MACHC,gBAAgB,EAAE,EAAE;MACpBC,iBAAiB,EAAE,EAAE;MACrBC,YAAY,EAAE,EAAE;MAChBC,WAAW,EAAE,EAAE;MACfC,qBAAqB,EAAE,EAAE;MACzBC,6BAA6B,EAAE,EAAE;MACjCC,wBAAwB,EAAE;IAC9B,CAAC;EACL,CAAC;EACDC,OAAO,EAAE;IACL,MAAMC,cAAcA,CAAA,EAAG;MACnB,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAAC,oCAAoC,CAAC;MAClE,MAAMC,KAAI,GAAI,MAAMC,OAAO,CAACC,IAAI,CAAC,CAAC;MAClC,IAAI,CAACb,gBAAe,GAAIW,KAAK;IACjC,CAAC;IACD,MAAMG,YAAYA,CAAA,EAAG;MACjB,MAAML,QAAO,GAAI,MAAMC,KAAK,CAAC,iCAAiC,CAAC;MAC/D,MAAMC,KAAI,GAAI,MAAMF,QAAQ,CAACI,IAAI,CAAC,CAAC;MACnC,IAAI,CAACZ,iBAAgB,GAAIU,KAAK,CAACI,WAAW;MAC1C,IAAI,CAACb,YAAW,GAAIS,KAAK,CAACK,OAAO;IACrC,CAAC;IACD,MAAMC,UAAUA,CAAA,EAAG;MACf,MAAMR,QAAO,GAAI,MAAMC,KAAK,CAAC,iCAAiC,CAAC;MAC/D,MAAMC,KAAI,GAAI,MAAMF,QAAQ,CAACI,IAAI,CAAC,CAAC;MACnC,IAAI,CAACX,YAAW,GAAIS,KAAK,CAACK,OAAO;IACrC,CAAC;IACD,MAAME,WAAWA,CAACC,CAAC,EAAE;MACjB,MAAMC,WAAU,GAAI;QAChBC,IAAI,EAAE,IAAI,CAAClB,WAAW;QACtBmB,KAAK,EAAE,IAAI,CAAClB,qBAAqB;QACjCY,OAAO,EAAEO,KAAK,CAACC,IAAI,CAAC,IAAI,CAAClB,wBAAwB,CAAC;QAClDS,WAAW,EAAEQ,KAAK,CAACC,IAAI,CAAC,IAAI,