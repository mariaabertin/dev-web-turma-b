{"ast":null,"code":"export default {\n  name: \"PedidoComponent\",\n  props: {\n    burguer: null\n  },\n  data() {\n    return {\n      listaPontosCarne: []\n    };\n  },\n  methods: {\n    async getTiposPontos() {\n      const response = await fetch(\"http://localhost:3000/tipos_pontos\");\n      const dados = await respose.json();\n      this.listaPontosCarne = dados;\n    }\n  },\n  mounted() {\n    this.getTiposPontos();\n  }\n};","map":{"version":3,"names":["name","props","burguer","data","listaPontosCarne","methods","getTiposPontos","response","fetch","dados","respose","json","mounted"],"sources":["C:\\Users\\bertinmaria\\Desktop\\githubMB\\dev-web-turma-b\\MariaClaraBertin\\ProjetoFinal\\tburguer\\src\\components\\PedidoComponent.vue"],"sourcesContent":["<template>\r\n    <div>\r\n        <form id=\"pedido-form\">\r\n        <div>\r\n            <p id=\"nome-hamburguer-content\">\r\n                {{ burguer && burguer.nome ? burguer.nome : \"--\"}}\r\n            </p>\r\n            <img id=\"foto-content\" :src=\"burguer && burguer.foto ? burguer.foto : ''\">\r\n        </div>\r\n\r\n        <div class=\"inputs\" id=\"form-pedido\">\r\n            <label>Nome</label>\r\n            <input type=\"text\" placeholder=\"Digite seu Nome\" id=\"nome-cliente\">\r\n        </div>\r\n\r\n        <div class=\"inputs\" id=\"form-pedido\">\r\n            <label>Ponto da Carne</label>\r\n            <select name=\"ponto-carne\" id=\"ponto-carne\">\r\n                <option value=\"\" selected>Selecione Ponto</option>\r\n                <option v-for=\"pontoCarne in listaPontosCarne\" :key=\"pontoCarne.id\" value=\"pontoCarne\">{{pontoCarne.descricao}}</option>\r\n            </select>\r\n        </div>\r\n\r\n        <div class=\"inputs\" id=\"form-pedido\">\r\n            <label id=\"opcionais-titulo\">Selecione os opcionais</label>\r\n            \r\n            <label id=\"opcionais-subtitulo\">Selecione os complementos</label>\r\n            <div class=\"checkbox-container\">\r\n                <input type=\"checkbox\">\r\n                <span>Batata</span>\r\n            </div>\r\n\r\n            <label>Adicione uma bebida</label>\r\n            <div class=\"checkbox-container\">\r\n                <input type=\"checkbox\">\r\n                <span>Água com gás</span>\r\n            </div>\r\n        </div>\r\n\r\n        <div class=\"inputs\">\r\n            <input type=\"submit\" class=\"submit-btn\" value=\"Confirmar Pedido\">\r\n        </div>\r\n        </form>\r\n    </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n    name: \"PedidoComponent\",\r\n    props: {\r\n        burguer: null,\r\n    },\r\n    data() {\r\n        return {\r\n            listaPontosCarne: [],\r\n        };\r\n    },\r\n    methods: {\r\n        async getTiposPontos() {\r\n            const response = await fetch(\"http://localhost:3000/tipos_pontos\");\r\n            const dados = await respose.json();\r\n            this.listaPontosCarne = dados;\r\n        },\r\n\r\n    },\r\n    mounted() {\r\n        this.getTiposPontos();\r\n    },\r\n};\r\n</script>\r\n\r\n<style></style>"],"mappings":"AA+CA,eAAe;EACXA,IAAI,EAAE,iBAAiB;EACvBC,KAAK,EAAE;IACHC,OAAO,EAAE;EACb,CAAC;EACDC,IAAIA,CAAA,EAAG;IACH,OAAO;MACHC,gBAAgB,EAAE;IACtB,CAAC;EACL,CAAC;EACDC,OAAO,EAAE;IACL,MAAMC,cAAcA,CAAA,EAAG;MACnB,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAAC,oCAAoC,CAAC;MAClE,MAAMC,KAAI,GAAI,MAAMC,OAAO,CAACC,IAAI,CAAC,CAAC;MAClC,IAAI,CAACP,gBAAe,GAAIK,KAAK;IACjC;EAEJ,CAAC;EACDG,OAAOA,CAAA,EAAG;IACN,IAAI,CAACN,cAAc,CAAC,CAAC;EACzB;AACJ,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}