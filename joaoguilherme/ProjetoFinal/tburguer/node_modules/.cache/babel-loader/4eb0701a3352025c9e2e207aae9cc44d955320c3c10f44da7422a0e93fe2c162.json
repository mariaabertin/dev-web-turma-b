{"ast":null,"code":"export default {\n  name: \"MenuView\",\n  data() {\n    return {\n      listaMenuHamburguers: []\n    };\n  },\n  methods: {\n    async consultarMenu() {\n      const response = await fetch(\"http://localhost:3000/menu\");\n      const dados = await response.json();\n      this.listaMenuHamburguers = dados.burgues;\n      console.log(this.listaMenuHamburguers);\n    }\n  },\n  mounted() {\n    this.consultarMenu();\n  }\n};","map":{"version":3,"names":["name","data","listaMenuHamburguers","methods","consultarMenu","response","fetch","dados","json","burgues","console","log","mounted"],"sources":["C:\\Users\\joaoguilhermesf\\dev-web-turma-b\\joaoguilherme\\ProjetoFinal\\tburguer\\src\\views\\MenuView.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <h1>Menu</h1>\r\n    <div id=\"scroll-horizontal\">\r\n      <div id=\"card-content\" v-for=\"burguer in listaMenuHamburguers\" :key=\"burguer.id\">\r\n        <div id=\"card-linha\">\r\n          <div class=\"foto-hamburguer\">\r\n            <img\r\n              width=\"300\"\r\n              height=\"200\"\r\n              :src=\"burguer.foto\">\r\n            <div class=\"card-coluna\">\r\n              <p id=\"nome-content\">{{ burguer.nome }}</p>\r\n              <p id=\"preco-content\">R$ {{ burguer.valor }}</p>\r\n              <p id=\"descricao-content\">{{burguer.descricao}}</p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n<script>\r\nexport default {\r\n  name: \"MenuView\",\r\n  data() {\r\n    return {\r\n      listaMenuHamburguers: [],\r\n    };\r\n  },\r\n  methods: {\r\n    async consultarMenu() {\r\n      const response = await fetch(\"http://localhost:3000/menu\");\r\n      const dados = await response.json();\r\n      this.listaMenuHamburguers = dados.burgues;\r\n      console.log(this.listaMenuHamburguers);\r\n     \r\n  },\r\n  },\r\n  mounted() {\r\n    this.consultarMenu();\r\n  }\r\n};\r\n</script>\r