{
  "name": "petspa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "deploy": "gh-pages -d dist",
    "serve:api": "json-server --watch db/db.json --port 3000",
    "serve:local": "node node_modules/@vue/cli-service/bin/vue-cli-service.js serve | node node_modules/json-server/lib/cli/bin.js --watch db/db.json --port 3000"
  },
  "dependencies": {
    "core-js": "^3.8.3",
    "json-server": "^0.17.4",
    "vue": "^3.2.13",
    "vue-router": "^4.0.3"
  },
  "devDependencies": {
    "@vue/cli-plugin-babel": "~5.0.0",
    "@vue/cli-plugin-router": "~5.0.0",
    "@vue/cli-service": "~5.0.0",
    "gh-pages": "^6.3.0"
  }
}