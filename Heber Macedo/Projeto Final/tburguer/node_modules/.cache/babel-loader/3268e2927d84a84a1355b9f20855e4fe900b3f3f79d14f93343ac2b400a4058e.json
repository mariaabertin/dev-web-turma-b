{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: \"MenuView\",\n  data() {\n    return {\n      listaMenuHamburguers: []\n    };\n  },\n  methods: {\n    async consultarMenu() {\n      const response = await fetch(\"http://localhost:3000/menu\");\n      const dados = await response.json();\n      this.listaMenuHamburguers = dados.burgues;\n      console.log(this.listaMenuHamburguers);\n    },\n    selecionarHamburguer(burguerSelecionado) {\n      const param = JSON.stringify(burguerSelecionado);\n      const burguerJson = encodeURIComponent(param);\n      this.$router.push({\n        path: \"/configuracao-pedido\",\n        query: {\n          burguer: burguerJson\n        }\n      });\n    }\n  },\n  mounted() {\n    this.consultarMenu();\n  }\n};","map":{"version":3,"names":["name","data","listaMenuHamburguers","methods","consultarMenu","response","fetch","dados","json","burgues","console","log","selecionarHamburguer","burguerSelecionado","param","JSON","stringify","burguerJson","encodeURIComponent","$router","push","path","query","burguer","mounted"],"sources":["C:\\Users\\heber.macedo\\Downloads\\GitHub Heber Macedo\\dev-web-turma-b\\Heber Macedo\\Projeto Final\\tburguer\\src\\views\\MenuView.vue"],"sourcesContent":["<template>\n  <div>\n    <h1>Menu</h1>\n    <div id=\"scroll-horizontal\">\n      <div\n        id=\"card-content\"\n        v-for=\"burguer in listaMenuHamburguers\"\n        :key=\"burguer.id\"\n      >\n        <div id=\"card-linha\">\n          <div class=\"foto-hamburguer\">\n            <img :src=\"burguer.foto\" />\n            <div class=\"card-coluna\">\n              <p id=\"nome-content\">{{ burguer.nome }}</p>\n              <p id=\"preco-content\">R$ {{ burguer.valor }},00</p>\n              <p id=\"descricao-content\">{{ burguer.descricao }}</p>\n              <button @click=\"selecionarHamburguer(burguer)\">Selecionar</button>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n<script>\nexport default {\n  name: \"MenuView\",\n  data() {\n    return {\n      listaMenuHamburguers: [],\n    };\n  },\n  methods: {\n    async consultarMenu() {\n      const response = await fetch(\"http://localhost:3000/menu\");\n      const dados = await response.json();\n      this.listaMenuHamburguers = dados.burgues;\n      console.log(this.listaMenuHamburguers);\n    },\n    selecionarHamburguer(burguerSelecionado) {\n      const param = JSON.stringify(burguerSelecionado);\n      const burguerJson = encodeURIComponent(param);\n      this.$router.push({ path: \"/configuracao-pedido\", query: { burguer: burguerJson } });\n    },\n  },\n  mounted() {\n    this.consultarMenu();\n  },\n};\n</script>\n<style scoped>\n#card-content {\n  display: inline-block;\n  width: 280px;\n  min-height: 500px;\n  margin: 20px;\n  border: 1px solid #ddd;\n  border-radius: 10px;\n  overflow: hidden;\n  box-shadow: 0 4px 8px #444;\n  position: relative;\n}\n\n#scroll-horizontal {\n  flex: 1;\n  overflow-x: auto;\n  white-space: nowrap;\n  width: 900px;\n  margin: 0 auto;\n  box-shadow: inset -10px 0px 15px -20px grey;\n}\n\n#nome-content {\n  font-size: 30px;\n  font-weight: bold;\n  text-align: center;\n  width: 100%;\n  margin: 12px;\n}\n\n.foto-hamburguer {\n  flex-shrink: 0;\n}\n\n.foto-hamburguer img {\n  width: 100%;\n  max-height: 200px;\n  object-fit: cover;\n}\n\n#preco-content {\n  font-size: 35px;\n  font-weight: bold;\n  text-align: center;\n  color: darkgreen;\n}\n\n#descricao-content {\n  font-size: 16px;\n  text-align: left;\n  color: gray;\n  margin: 16px;\n  white-space: pre-line;\n  text-overflow: ellipsis;\n  overflow: hidden;\n  display: -webkit-box;\n  -webkit-line-clamp: 6;\n  -webkit-box-orient: vertical;\n}\n\n.card-linha {\n  display: flex;\n  flex-direction: row;\n  height: 100%;\n}\n\n.card-coluna {\n  flex-grow: 1;\n  padding: 15px;\n  height: 100%;\n}\n\n.card-coluna button {\n  padding: 10px;\n  width: 100%;\n  border-radius: 10px;\n  border: none;\n  color: white;\n  background-color: green;\n  cursor: pointer;\n  transition: 0.5s;\n}\n\n.card-coluna button:hover {\n  color: green;\n  background-color: rgb(0, 37, );\n</style>\n"],"mappings":";AAyBA,eAAe;EACbA,IAAI,EAAE,UAAU;EAChBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,oBAAoB,EAAE;IACxB,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,aAAaA,CAAA,EAAG;MACpB,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAAC,4BAA4B,CAAC;MAC1D,MAAMC,KAAI,GAAI,MAAMF,QAAQ,CAACG,IAAI,CAAC,CAAC;MACnC,IAAI,CAACN,oBAAmB,GAAIK,KAAK,CAACE,OAAO;MACzCC,OAAO,CAACC,GAAG,CAAC,IAAI,CAACT,oBAAoB,CAAC;IACxC,CAAC;IACDU,oBAAoBA,CAACC,kBAAkB,EAAE;MACvC,MAAMC,KAAI,GAAIC,IAAI,CAACC,SAAS,CAACH,kBAAkB,CAAC;MAChD,MAAMI,WAAU,GAAIC,kBAAkB,CAACJ,KAAK,CAAC;MAC7C,IAAI,CAACK,OAAO,CAACC,IAAI,CAAC;QAAEC,IAAI,EAAE,sBAAsB;QAAEC,KAAK,EAAE;UAAEC,OAAO,EAAEN;QAAY;MAAE,CAAC,CAAC;IACtF;EACF,CAAC;EACDO,OAAOA,CAAA,EAAG;IACR,IAAI,CAACpB,aAAa,CAAC,CAAC;EACtB;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}